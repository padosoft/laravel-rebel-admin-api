# ============================================================================
# laravel-rebel-admin-api — environment variables
# ============================================================================

# Where the JSON endpoints are mounted.
REBEL_ADMIN_API_PREFIX=rebel/admin/api/v1

# Auth guard the request must be authenticated on ('' = the app default guard).
REBEL_ADMIN_API_GUARD=

# Gate ability the user must pass. Default 'rebel-admin' is FAIL-CLOSED: define that
# Gate (or change this) to grant access. Set to '' only if the guard already implies admin.
REBEL_ADMIN_API_ABILITY=rebel-admin
